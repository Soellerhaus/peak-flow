{
  "appId": "app.peakflow.www",
  "appName": "Peakflow",
  "webDir": "www",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#1a1a1a"
    },
    "Geolocation": {
      "enableHighAccuracy": true
    },
    "ForegroundService": {
      "channelName": "Peak Flow Navigation",
      "channelDescription": "GPS Navigation im Hintergrund"
    }
  }
}
